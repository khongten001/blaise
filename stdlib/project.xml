<?xml version="1.0" encoding="UTF-8"?>
<project>
  <name>blaise-stdlib</name>

  <build>
    <packaging>library</packaging>
    <unitPaths>
      <!-- The RTL units (runtime.*.pas) live in the compiler's own source
           tree; runtime/src/main/pascal no longer exists. -->
      <path>../compiler/src/main/pascal</path>
    </unitPaths>
    <bootstrapExclude>
      <unit>Net.Tls.Provider</unit>
      <unit>Net.Tls</unit>
      <unit>Net.Http.Client.Tls</unit>
      <!-- FreeBSD-only reactor: defines the same link-time CreateOsReactor
           symbol as async.reactor.epoll, so a bootstrap program holding BOTH
           fails with a duplicate identifier.  The per-OS reactor is selected
           by the driver's unit list, not by this all-units program. -->
      <unit>async.reactor.kqueue</unit>
    </bootstrapExclude>
  </build>

  <test>
    <framework>blaise</framework>
    <testSource>testrunner.pas</testSource>
  </test>

</project>
